<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen">

    <ScrollView
        android:id="@+id/mainScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvMainTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your scrolls"
                android:textSize="28sp"
                android:textColor="@color/ink"
                android:fontFamily="serif" />

            <Button
                android:id="@+id/btnLogout"
                style="@style/Widget.Unscroll.Button.Secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log out"
                android:textColor="@color/ink" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_pill"
            android:text="Service status"
            android:textColor="@color/slate"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/scoreCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvScoreLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
            android:text="Today's scroll count"
                android:textColor="@color/slate"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvScrollScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="40sp"
                android:textColor="@color/ink"
                android:fontFamily="serif"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnStopAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop alarm"
            android:backgroundTint="@color/coral"
            android:textColor="@color/cream"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/leaderboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvLeaderboardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Friends leaderboard"
                android:textSize="16sp"
                android:textColor="@color/ink"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTopRanks"
                android:layout_width="match_parent"
                android:layout_height="220dp" />

            <TextView
                android:id="@+id/tvTopEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No friends yet."
                android:textColor="@color/slate"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnViewAll"
                style="@style/Widget.Unscroll.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="View full leaderboard"
                android:textColor="@color/ink"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnFriends"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Friends"
            android:backgroundTint="@color/teal"
            android:textColor="@color/cream"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAlarmSettings"
            style="@style/Widget.Unscroll.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alarm settings"
            android:textColor="@color/ink"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSelectApps"
            style="@style/Widget.Unscroll.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select apps"
            android:textColor="@color/ink" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
