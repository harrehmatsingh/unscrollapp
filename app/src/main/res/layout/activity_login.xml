<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:padding="24dp">

    <View
        android:id="@+id/orbTeal"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/bg_orb_teal"
        android:alpha="0.18"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        android:layout_marginEnd="-24dp"
        android:layout_marginTop="-24dp" />

    <View
        android:id="@+id/orbCoral"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_orb_coral"
        android:alpha="0.18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="-12dp"
        android:layout_marginTop="72dp" />

    <LinearLayout
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvLoginTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Unscroll"
            android:textSize="34sp"
            android:textColor="@color/ink"
            android:fontFamily="serif"
            android:letterSpacing="0.02"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLoginSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track your scrolls and take back your time."
            android:textColor="@color/slate"
            android:textSize="16sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGoogleSignIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Continue with Google"
            android:backgroundTint="@color/teal"
            android:textColor="@color/cream"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnSkip"
            style="@style/Widget.Unscroll.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Skip for now"
            android:textColor="@color/ink" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
