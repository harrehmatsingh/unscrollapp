<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UnscrollApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/teal</item>
        <item name="colorOnPrimary">@color/cream</item>
        <item name="colorSecondary">@color/coral</item>
        <item name="colorOnSecondary">@color/cream</item>
        <item name="colorTertiary">@color/amber</item>
        <item name="colorOnTertiary">@color/ink</item>
        <item name="android:colorBackground">@color/cream</item>
        <item name="colorOnBackground">@color/ink</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorOutline">@color/outline</item>

        <item name="android:statusBarColor">@color/cream</item>
        <item name="android:navigationBarColor">@color/cream</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="materialButtonStyle">@style/Widget.Unscroll.Button</item>
    </style>

    <style name="Theme.UnscrollApplication" parent="Base.Theme.UnscrollApplication" />

    <style name="Widget.Unscroll.Button" parent="Widget.Material3.Button">
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.Unscroll.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/outline</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
</resources>
